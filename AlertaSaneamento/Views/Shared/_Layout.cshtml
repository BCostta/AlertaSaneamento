<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0" />
    <title>@ViewData["Title"] - Alerta Saneamento</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/AlertaSaneamento.styles.css" asp-append-version="true" />
    <style>
        body { background-color: #f8f9fa; }

        /* Navbar */
        .navbar-brand { font-weight: 700; color: #1a6e3c !important; font-size: 1.2rem; }
        .navbar { background-color: #ffffff; border-bottom: 3px solid #1a6e3c; }
        .nav-link { color: #333 !important; font-weight: 500; padding: 0.6rem 0.8rem !important; }
        .nav-link:hover { color: #1a6e3c !important; }

        /* Menu mobile: itens com separador visual */
        @@media (max-width: 991px) {
            .navbar-nav .nav-item + .nav-item {
                border-top: 1px solid #f0f0f0;
            }
            .navbar-nav .btn {
                margin: 0.4rem 0.8rem;
                display: block;
                text-align: center;
            }
        }

        /* Inputs maiores no mobile para facilitar toque */
        @@media (max-width: 576px) {
            .form-control, .form-select, .btn {
                font-size: 1rem;
                min-height: 44px;
            }
        }

        /* Footer */
        footer { background-color: #1a6e3c; color: #fff; padding: 1.5rem 0; margin-top: 3rem; }
        footer a { color: #a8d5b5; }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-light">
            <div class="container">
                <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                    🌊 Alerta Saneamento
                </a>
                <button class="navbar-toggler border-0" type="button"
                        data-bs-toggle="collapse" data-bs-target="#navbarMenu"
                        aria-controls="navbarMenu" aria-expanded="false" aria-label="Abrir menu">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarMenu">
                    <ul class="navbar-nav ms-auto">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">Início</a>
                        </li>
                        @if (Context.Session.GetString("UsuarioId") != null)
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Alerta" asp-action="Index">
                                    @(Context.Session.GetString("UsuarioTipo") == "Fiscal" ? "Todos os Alertas" : "Meus Alertas")
                                </a>
                            </li>
                            @if (Context.Session.GetString("UsuarioTipo") == "Cidadao")
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Alerta" asp-action="Create">+ Novo Alerta</a>
                                </li>
                            }
                            @if (Context.Session.GetString("UsuarioTipo") == "Fiscal")
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Usuario" asp-action="CadastroFiscal">+ Cadastrar Fiscal</a>
                                </li>
                            }
                            <li class="nav-item">
                                <a class="nav-link text-danger" asp-controller="Usuario" asp-action="Logout">
                                    Sair (@Context.Session.GetString("UsuarioNome"))
                                </a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Usuario" asp-action="Login">Entrar</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link btn btn-success text-white ms-lg-2 px-3"
                                   asp-controller="Usuario" asp-action="Cadastro">Cadastrar</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main role="main">
        @RenderBody()
    </main>

    <footer>
        <div class="container text-center">
            <p class="mb-1">🌊 <strong>Alerta Saneamento</strong> — Fiscalização cidadã do saneamento básico</p>
            <small>&copy; @DateTime.Now.Year — Todos os direitos reservados</small>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
